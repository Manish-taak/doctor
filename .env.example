# Copy the relevant variables into packages/database/.env, apps/api/.env, and apps/web/.env.local
# Uses a locally-installed Postgres (no Docker) — update user/password/port to match your local setup.

# --- packages/database/.env & apps/api/.env ---
DATABASE_URL="postgresql://postgres:2018@localhost:5432/doctor?schema=public"

# --- apps/api/.env ---
PORT=4000
JWT_SECRET="dev-only-change-me"
JWT_EXPIRES_IN="7d"
CORS_ORIGIN="http://localhost:3000"

# --- apps/web/.env.local ---
AUTH_SECRET="dev-only-change-me"
NEXTAUTH_URL="http://localhost:3000"
API_URL="http://localhost:4000"
NEXT_PUBLIC_API_URL="http://localhost:4000"
