# Copy the relevant variables into packages/database/.env, apps/api/.env, and apps/web/.env.local
# (docker-compose.yml already matches these defaults for local dev)

# --- packages/database/.env & apps/api/.env ---
DATABASE_URL="postgresql://doctor:doctor@localhost:5433/doctor?schema=public"

# --- apps/api/.env ---
PORT=4000
JWT_SECRET="dev-only-change-me"
JWT_EXPIRES_IN="7d"
CORS_ORIGIN="http://localhost:3000"

# --- apps/web/.env.local ---
AUTH_SECRET="dev-only-change-me"
NEXTAUTH_URL="http://localhost:3000"
API_URL="http://localhost:4000"
NEXT_PUBLIC_API_URL="http://localhost:4000"
